# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/

# Ignore storage (uploaded files in development and not in production)
/storage/*
!/storage/.keep

# Ignore master key for Rails credentials.
/config/master.key
/config/credentials/*.key

# OS files
.DS_Store

# IDE files
.idea/
.vscode/

# Node modules (for asset compilation)
node_modules/
