<div class="w-full max-w-md">
  <%# Logo / Brand %>
  <div class="text-center mb-8">
    <div class="inline-flex items-center gap-2 mb-2">
      <div class="w-9 h-9 bg-indigo-600 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <span class="text-white text-2xl font-bold tracking-tight">VaultShare</span>
    </div>
    <p class="text-gray-400 text-sm">Sign in to your workspace</p>
  </div>

  <%# Card %>
  <div class="bg-gray-900 border border-gray-800 rounded-2xl shadow-2xl p-8">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="space-y-5">
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "w-full bg-gray-800 border border-gray-700 text-white placeholder-gray-500
                      rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2
                      focus:ring-indigo-500 focus:border-transparent transition",
              placeholder: "you@example.com" %>
        </div>

        <div>
          <div class="flex items-center justify-between mb-1.5">
            <%= f.label :password, class: "block text-sm font-medium text-gray-300" %>
            <% if devise_mapping.recoverable? && controller_name != "passwords" %>
              <%= link_to "Forgot password?", new_password_path(resource_name),
                  class: "text-xs text-indigo-400 hover:text-indigo-300 transition" %>
            <% end %>
          </div>
          <%= f.password_field :password,
              autocomplete: "current-password",
              class: "w-full bg-gray-800 border border-gray-700 text-white placeholder-gray-500
                      rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2
                      focus:ring-indigo-500 focus:border-transparent transition",
              placeholder: "••••••••" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-gray-600 bg-gray-800 text-indigo-600 focus:ring-indigo-500" %>
            <%= f.label :remember_me, class: "text-sm text-gray-400" %>
          </div>
        <% end %>

        <%= f.submit "Sign in",
            class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold
                    rounded-lg py-2.5 px-4 text-sm transition cursor-pointer mt-2" %>
      </div>
    <% end %>

    <p class="text-center text-sm text-gray-500 mt-6">
      New to VaultShare?
      <%= link_to "Create an account", new_registration_path(resource_name),
          class: "text-indigo-400 hover:text-indigo-300 font-medium transition" %>
    </p>
  </div>
</div>
