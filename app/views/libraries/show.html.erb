<% content_for :title, "#{@library.name} — VaultShare" %>

<%# Header %>
<div class="flex items-start justify-between mb-6">
  <div>
    <%= link_to libraries_path, class: "text-xs text-gray-500 hover:text-gray-300 transition flex items-center gap-1 mb-2" do %>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Libraries
    <% end %>
    <div class="flex items-center gap-3">
      <h1 class="text-xl font-bold text-white"><%= @library.name %></h1>
      <span class="text-xs px-2 py-0.5 rounded-full <%= @library.shared? ? 'bg-emerald-900/50 text-emerald-400' : 'bg-gray-800 text-gray-500' %>">
        <%= @library.shared? ? "Shared" : "Private" %>
      </span>
    </div>
    <p class="text-xs text-gray-500 mt-1">Owned by <%= @library.user.email %></p>
  </div>

  <div class="flex items-center gap-2">
    <% if policy(@library).update? %>
      <%= link_to "Edit", edit_library_path(@library),
          class: "text-sm text-gray-400 hover:text-white border border-gray-700 hover:border-gray-600 px-3 py-1.5 rounded-lg transition" %>
    <% end %>
    <% if policy(@library).destroy? %>
      <%= button_to "Delete", library_path(@library), method: :delete,
          data: { turbo_confirm: "Delete this library and all its content?" },
          class: "text-sm text-red-400 hover:text-red-300 border border-red-800 hover:border-red-700 px-3 py-1.5 rounded-lg transition cursor-pointer bg-transparent" %>
    <% end %>
    <% if policy(Collection.new(library: @library)).create? %>
      <%= link_to "New Collection", new_library_collection_path(@library),
          class: "bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-4 py-1.5 rounded-lg transition" %>
    <% end %>
  </div>
</div>

<%# Collections grid %>
<% if @collections.any? %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @collections.each do |collection| %>
      <%= link_to library_collection_path(@library, collection),
          class: "group bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-gray-700 transition" do %>
        <div class="w-9 h-9 bg-indigo-600/10 rounded-lg flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
        </div>
        <h3 class="text-white font-medium group-hover:text-indigo-300 transition"><%= collection.name %></h3>
        <p class="text-xs text-gray-500 mt-1"><%= pluralize(collection.assets.size, "asset") %></p>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="bg-gray-900 border border-gray-800 border-dashed rounded-2xl p-12 text-center">
    <p class="text-gray-500 text-sm mb-3">No collections yet.</p>
    <% if policy(Collection.new(library: @library)).create? %>
      <%= link_to "Create a Collection", new_library_collection_path(@library),
          class: "text-indigo-400 hover:text-indigo-300 text-sm transition" %>
    <% end %>
  </div>
<% end %>
