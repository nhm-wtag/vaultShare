<%= form_with model: library, class: "space-y-5" do |f| %>
  <% if library.errors.any? %>
    <div class="bg-red-900/40 border border-red-700 rounded-lg px-4 py-3">
      <ul class="list-disc list-inside text-red-400 text-sm space-y-0.5">
        <% library.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
    <%= f.text_field :name,
        class: "w-full bg-gray-800 border border-gray-700 text-white placeholder-gray-500 rounded-lg
                px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition",
        placeholder: "e.g. Marketing_Assets" %>
  </div>

  <div>
    <%= f.label :visibility, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
    <%= f.select :visibility,
        [["Private — only visible to you", "restricted"], ["Shared — visible to all users", "shared"]],
        {},
        class: "w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-2.5 text-sm
                focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit library.persisted? ? "Update Library" : "Create Library",
        class: "bg-indigo-600 hover:bg-indigo-500 text-white font-medium text-sm px-5 py-2.5 rounded-lg transition cursor-pointer" %>
    <%= link_to "Cancel", library.persisted? ? library : libraries_path,
        class: "text-sm text-gray-500 hover:text-gray-300 px-4 py-2.5 transition" %>
  </div>
<% end %>
