<% content_for :title, "New Library — VaultShare" %>

<div class="max-w-lg">
  <div class="mb-6">
    <%= link_to libraries_path, class: "text-sm text-gray-500 hover:text-gray-300 transition flex items-center gap-1" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Libraries
    <% end %>
    <h1 class="text-xl font-bold text-white mt-2">New Library</h1>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
    <%= render "form", library: @library %>
  </div>
</div>
