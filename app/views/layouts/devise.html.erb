<!DOCTYPE html>
<html>
  <head>
    <title>VaultShare</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-gray-950 min-h-screen flex items-center justify-center p-4">
    <% if notice %>
      <div id="flash-notice" class="fixed top-4 right-4 z-50 bg-indigo-600 text-white px-4 py-3 rounded-lg shadow-lg text-sm">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div id="flash-alert" class="fixed top-4 right-4 z-50 bg-red-600 text-white px-4 py-3 rounded-lg shadow-lg text-sm">
        <%= alert %>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
