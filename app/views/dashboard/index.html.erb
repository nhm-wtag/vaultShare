<% content_for :title, "Dashboard — VaultShare" %>

<div class="mb-6">
  <h1 class="text-xl font-bold text-white">Dashboard</h1>
  <p class="text-gray-500 text-sm mt-0.5">Welcome back, <%= current_user.email.split("@").first %></p>
</div>

<%# Stats %>
<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Libraries</p>
    <p class="text-3xl font-bold text-white mt-1"><%= @stats[:libraries] %></p>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Collections</p>
    <p class="text-3xl font-bold text-white mt-1"><%= @stats[:collections] %></p>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Assets</p>
    <p class="text-3xl font-bold text-white mt-1"><%= @stats[:assets] %></p>
  </div>
</div>

<div class="grid grid-cols-2 gap-6">
  <%# Recent Libraries %>
  <div>
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold text-gray-300">Recent Libraries</h2>
      <%= link_to "View all", libraries_path, class: "text-xs text-indigo-400 hover:text-indigo-300 transition" %>
    </div>
    <% if @recent_libraries.any? %>
      <div class="space-y-2">
        <% @recent_libraries.each do |library| %>
          <%= link_to library_path(library), class: "flex items-center justify-between bg-gray-900 border border-gray-800 rounded-lg px-4 py-3 hover:border-gray-700 transition" do %>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-indigo-600/20 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-white"><%= library.name %></p>
                <p class="text-xs text-gray-500"><%= library.collections.size %> collections</p>
              </div>
            </div>
            <span class="text-xs px-2 py-0.5 rounded-full <%= library.shared? ? 'bg-emerald-900/50 text-emerald-400' : 'bg-gray-800 text-gray-500' %>">
              <%= library.shared? ? "Shared" : "Private" %>
            </span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-gray-900 border border-gray-800 border-dashed rounded-xl p-6 text-center">
        <p class="text-gray-500 text-sm">No libraries yet.</p>
        <% if policy(Library.new).create? %>
          <%= link_to "Create one", new_library_path, class: "text-indigo-400 hover:text-indigo-300 text-sm transition" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Recent Activity %>
  <div>
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold text-gray-300">Recent Activity</h2>
      <%= link_to "View all", activity_logs_path, class: "text-xs text-indigo-400 hover:text-indigo-300 transition" %>
    </div>
    <% if @recent_logs.any? %>
      <div class="space-y-2">
        <% @recent_logs.each do |log| %>
          <div class="flex items-center gap-3 bg-gray-900 border border-gray-800 rounded-lg px-4 py-3">
            <span class="text-xs px-2 py-0.5 rounded-full font-medium
              <%= log.action == 'upload' ? 'bg-indigo-900/50 text-indigo-400' :
                  log.action == 'download' ? 'bg-emerald-900/50 text-emerald-400' :
                  'bg-gray-800 text-gray-400' %>">
              <%= log.action.capitalize %>
            </span>
            <p class="text-sm text-gray-300 truncate flex-1"><%= log.asset.title %></p>
            <p class="text-xs text-gray-600 flex-shrink-0"><%= time_ago_in_words(log.created_at) %> ago</p>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-gray-900 border border-gray-800 border-dashed rounded-xl p-6 text-center">
        <p class="text-gray-500 text-sm">No activity yet.</p>
      </div>
    <% end %>
  </div>
</div>
