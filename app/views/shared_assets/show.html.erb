<div class="w-full max-w-2xl">
  <%# Brand header %>
  <div class="text-center mb-8">
    <div class="inline-flex items-center gap-2 mb-1">
      <div class="w-7 h-7 bg-indigo-600 rounded-lg flex items-center justify-center">
        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
      </div>
      <span class="text-white font-bold text-lg tracking-tight">VaultShare</span>
    </div>
    <p class="text-gray-500 text-xs">Shared asset</p>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden shadow-2xl">
    <%# File preview %>
    <% if @asset.files.attached? %>
      <% file = @asset.files.first %>
      <% if @asset.image? %>
        <%= image_tag url_for(file), class: "w-full max-h-80 object-contain bg-gray-950", alt: @asset.title %>
      <% elsif @asset.audio? %>
        <div class="p-6 bg-gray-950">
          <audio controls class="w-full">
            <source src="<%= url_for(file) %>" type="<%= file.content_type %>">
          </audio>
        </div>
      <% elsif @asset.pdf? %>
        <div class="p-6 bg-gray-950 flex items-center gap-3">
          <div class="w-12 h-12 bg-red-600/20 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-white text-sm font-medium"><%= file.filename %></p>
            <p class="text-xs text-gray-500">PDF Document</p>
          </div>
        </div>
      <% end %>
    <% end %>

    <%# Asset info %>
    <div class="p-6">
      <h1 class="text-lg font-bold text-white mb-1"><%= @asset.title %></h1>
      <% if @asset.description.present? %>
        <p class="text-sm text-gray-400 mb-4"><%= @asset.description %></p>
      <% end %>

      <div class="flex items-center gap-4 text-xs text-gray-600 mb-5">
        <span><%= @library.name %> / <%= @collection.name %></span>
        <span><%= @asset.formatted_size %></span>
        <span>Expires <%= @asset.share_token_expires_at.strftime("%b %d, %Y") %></span>
      </div>

      <%= link_to "Download File",
          rails_blob_path(@asset.files.first, disposition: "attachment"),
          class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-4 py-2.5 rounded-lg transition inline-block text-center" %>
    </div>
  </div>

  <p class="text-center text-xs text-gray-700 mt-6">
    This is a shared link from VaultShare. It will expire on <%= @asset.share_token_expires_at.strftime("%B %d, %Y") %>.
  </p>
</div>
