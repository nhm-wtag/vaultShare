<% content_for :title, "Activity Log — VaultShare" %>

<div class="mb-6">
  <h1 class="text-xl font-bold text-white">Activity Log</h1>
  <p class="text-gray-500 text-sm mt-0.5">
    <%= current_user.admin? ? "All user activity" : "Your recent activity" %>
  </p>
</div>

<% if @logs.any? %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-800">
          <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider px-5 py-3">Action</th>
          <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider px-5 py-3">Asset</th>
          <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider px-5 py-3">Library</th>
          <% if current_user.admin? %>
            <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider px-5 py-3">User</th>
          <% end %>
          <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider px-5 py-3">When</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-800">
        <% @logs.each do |log| %>
          <tr class="hover:bg-gray-800/50 transition">
            <td class="px-5 py-3">
              <span class="text-xs font-medium px-2 py-0.5 rounded-full
                <%= log.action == 'upload'   ? 'bg-indigo-900/50 text-indigo-400' :
                    log.action == 'download' ? 'bg-emerald-900/50 text-emerald-400' :
                    'bg-gray-800 text-gray-400' %>">
                <%= log.action.capitalize %>
              </span>
            </td>
            <td class="px-5 py-3 text-gray-300">
              <%= link_to log.asset.title,
                  library_collection_asset_path(
                    log.asset.collection.library,
                    log.asset.collection,
                    log.asset
                  ),
                  class: "hover:text-indigo-300 transition" %>
            </td>
            <td class="px-5 py-3 text-gray-500">
              <%= log.asset.collection.library.name %>
            </td>
            <% if current_user.admin? %>
              <td class="px-5 py-3 text-gray-500"><%= log.user.email %></td>
            <% end %>
            <td class="px-5 py-3 text-gray-600 text-xs">
              <%= log.created_at.strftime("%b %d, %Y %H:%M") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-gray-900 border border-gray-800 border-dashed rounded-2xl p-12 text-center">
    <p class="text-gray-500 text-sm">No activity recorded yet.</p>
  </div>
<% end %>
