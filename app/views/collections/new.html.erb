<% content_for :title, "New Collection — VaultShare" %>

<div class="max-w-lg">
  <div class="mb-6">
    <%= link_to library_path(@library), class: "text-sm text-gray-500 hover:text-gray-300 transition flex items-center gap-1" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= @library.name %>
    <% end %>
    <h1 class="text-xl font-bold text-white mt-2">New Collection</h1>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
    <%= form_with model: [@library, @collection], class: "space-y-5" do |f| %>
      <% if @collection.errors.any? %>
        <div class="bg-red-900/40 border border-red-700 rounded-lg px-4 py-3">
          <ul class="list-disc list-inside text-red-400 text-sm">
            <% @collection.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.text_field :name,
            class: "w-full bg-gray-800 border border-gray-700 text-white placeholder-gray-500 rounded-lg
                    px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition",
            placeholder: "e.g. Q1_Launch" %>
      </div>

      <div class="flex gap-3 pt-2">
        <%= f.submit "Create Collection",
            class: "bg-indigo-600 hover:bg-indigo-500 text-white font-medium text-sm px-5 py-2.5 rounded-lg transition cursor-pointer" %>
        <%= link_to "Cancel", library_path(@library),
            class: "text-sm text-gray-500 hover:text-gray-300 px-4 py-2.5 transition" %>
      </div>
    <% end %>
  </div>
</div>
